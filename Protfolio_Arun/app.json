{
  "expo": {
    "name": "Arun Kumar Portfolio",
    "slug": "arun-portfolio",
    "version": "1.0.0",
    "orientation": "default",
    "scheme": "arunportfolio",
    "userInterfaceStyle": "dark",
    "web": {
      "output": "single",
      "bundler": "metro"
    },
    "plugins": [
      "expo-router",
      [
        "expo-splash-screen",
        {
          "backgroundColor": "#0a0a0a"
        }
      ]
    ],
    "experiments": {
      "typedRoutes": true,
      "reactCompiler": true
    }
  }
}
